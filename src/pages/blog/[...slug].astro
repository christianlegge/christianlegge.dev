---
import { getCollection } from "astro:content";
import BlogLayout from "../../layouts/BlogLayout.astro";
import BlogPost from "../../components/BlogPost.astro";
import { titleToSlug } from "../../util/blogTitle";

export const prerender = false;

const blogPosts = await getCollection("blog");

let post = blogPosts.find((page) => Astro.params.slug === page.slug);

if (post) {
	return Astro.redirect(titleToSlug(post.data.title));
}

post = blogPosts.find(
	(page) => Astro.params.slug === titleToSlug(page.data.title)
);

if (!post) {
	return Astro.rewrite("/404");
}

const firstPara = post.body.split("\n").find((el) => el.length > 80);
---

<BlogLayout
	title={post.data.title}
	image={post.data.image}
	description={firstPara ?? "A blog post by Christian Legge"}
>
	<a href="/blog" class="link mb-4 inline-block">&lt; Back</a>
	<BlogPost post={post} />
</BlogLayout>
