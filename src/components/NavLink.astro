---
export interface Props {
	page: string;
}

const { page } = Astro.props;
const current =
	page === "home"
		? Astro.url.pathname === "/"
		: Astro.url.pathname.startsWith(`/${page.toLowerCase()}`);
console.log(page);
---

<a
	href={`/${page === "home" ? "" : page.toLowerCase()}`}
	class={`relative z-10 before:absolute w-fit ${
		current
			? "opacity-100 before:left-0 before:w-full font-medium"
			: "opacity-70 before:left-1/2 before:w-0 before:transition-all hover:opacity-100 hover:before:left-0 hover:before:w-full"
	} before:-bottom-0.5 before:border-b before:border-white`}
>
	{page}
</a>
