---
export interface Props {
	page: string;
}

const { page } = Astro.props;
const current =
	page === "home"
		? Astro.url.pathname === "/"
		: Astro.url.pathname.startsWith(`/${page.toLowerCase()}`);
---

<a
	href={`/${page === "home" ? "" : page.toLowerCase()}`}
	class={`not-italic! no-underline! relative z-10 before:absolute w-fit before:-bottom-0.5 before:border-b before:border-fuchsia-100 ${
		current
			? "opacity-100 before:left-0 before:w-full font-medium"
			: "text-white! opacity-70 before:left-1/2 before:w-0 font-light! before:transition-all hover:opacity-100 hover:before:left-0 hover:before:w-full"
	}`}
>
	{page}
</a>
