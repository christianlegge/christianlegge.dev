---
import { getCollection } from "astro:content";
import Layout from "./Layout.astro";
import { titleToSlug } from "../util/blogTitle";

export interface Props {
	title: string;
	image?: string;
	description?: string;
}

const { title, image, description } = Astro.props;

const posts = await getCollection("blog");
posts.sort((a, b) => b.slug.localeCompare(a.slug));
---

<Layout title={title} image={image} description={description}>
	<section class="col-span-2 lg:col-span-1 lg:col-start-2">
		<slot />
	</section>
	<aside
		class="mx-auto max-w-screen p-8 text-left max-lg:w-[65ch] lg:text-right"
		slot="after-main"
	>
		<h3 class="text-sm tracking-wider uppercase opacity-75">Archive</h3>
		<ol class="space-y-2">
			{
				posts.map((post) => (
					<li>
						{Astro.url.pathname.includes(
							titleToSlug(post.data.title)
						) ? (
							<span>{post.data.title}</span>
						) : (
							<a
								href={`/blog/${titleToSlug(post.data.title)}`}
								class="link"
							>
								{post.data.title}
							</a>
						)}
					</li>
				))
			}
		</ol>
	</aside>
</Layout>
